FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    streamlit==1.31.0 \
    plotly==5.18.0 \
    requests==2.31.0 \
    python-dotenv==1.0.0 \
    streamlit-autorefresh==1.0.1

COPY dashboards/ ./dashboards/

EXPOSE 8501

CMD ["streamlit", "run", "dashboards/streamlit_app.py", \
     "--server.port=8501", \
     "--server.address=0.0.0.0", \
     "--server.headless=true"]
